#!/usr/bin/env bash
# longai — wrapper that bypasses `uv run` arch-flipping issues on Apple Silicon.
#
# Why: `uv run` re-syncs the venv under whatever arch it's invoked from. On
# Macs with rtk/shell wrappers that default to x86_64, `uv run longai ...`
# installs x86_64 wheels; subsequent arm64 Python invocations then can't load
# them ("incompatible architecture" ImportError). This wrapper forces arm64
# and calls the venv's Python directly — no uv re-sync.
#
# Usage:
#   ./longai run "what's 2+2"
#   ./longai chat
#   ./longai bot
#
# Install as a global CLI (any of these three):
#   1. Alias:    alias longai='/abs/path/to/repo/longai'
#   2. Symlink:  ln -sf "$(pwd)/longai" ~/.local/bin/longai   (needs ~/.local/bin in PATH)
#   3. PATH:     export PATH="/abs/path/to/repo:$PATH"
set -euo pipefail

# Resolve the wrapper's real location even when invoked through a symlink
# (so `~/.local/bin/longai -> /repo/longai` still finds the venv at /repo/.venv).
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "${SCRIPT_PATH}" ]; do
    LINK_DIR="$(cd -P "$(dirname "${SCRIPT_PATH}")" && pwd)"
    SCRIPT_PATH="$(readlink "${SCRIPT_PATH}")"
    [[ "${SCRIPT_PATH}" != /* ]] && SCRIPT_PATH="${LINK_DIR}/${SCRIPT_PATH}"
done
SCRIPT_DIR="$(cd -P "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}"

ARCH_PREFIX=""
if [ "$(uname)" = "Darwin" ] && [ "$(sysctl -n hw.optional.arm64 2>/dev/null)" = "1" ]; then
    ARCH_PREFIX="arch -arm64"
fi

PYBIN="${REPO_ROOT}/.venv/bin/python"
if [ ! -x "${PYBIN}" ]; then
    echo "ERROR: ${PYBIN} not found." >&2
    echo "       Run: bash scripts/setup_venv.sh" >&2
    exit 2
fi

unset VIRTUAL_ENV   # avoid rtk-set 'myenv' or other stale pointers

# Auto-load secrets from ~/.longai/env (dotenv-style KEY=VALUE file). Lets a
# global CLI install pick up OPENROUTER_API_KEY, TELEGRAM_BOT_TOKEN, etc.
# without forcing shell-rc edits in every terminal. Existing exports win —
# `set -a` only auto-exports new assignments, it doesn't overwrite a value
# that's already in the environment unless the file re-assigns it.
ENV_FILE="${HOME}/.longai/env"
if [ -f "${ENV_FILE}" ]; then
    set -a
    # shellcheck disable=SC1090
    . "${ENV_FILE}"
    set +a
fi

exec $ARCH_PREFIX "${PYBIN}" -m longai "$@"
