# longai env — copy to ~/.longai/env and edit.
#
# The `longai` wrapper auto-sources this file before launching, so you don't
# need to export these vars in every shell. Keeps secrets out of your shell-rc.
#
# Permissions: chmod 600 ~/.longai/env (owner read/write only).
#
# Precedence: env vars already exported in the shell win. The file only fills
# in what's missing, with one exception — if the file reassigns a var, the
# file's value wins (because `set -a` re-exports it). This means: prefer this
# file as the single source of truth for longai secrets.

# ── Required ────────────────────────────────────────────────────────────
# Get at https://openrouter.ai (free, no credit card needed for free models).
OPENROUTER_API_KEY=sk-or-v1-...

# ── Telegram bot mode ───────────────────────────────────────────────────
# Required for `longai bot`. Optional for chat / run / test.
# TELEGRAM_BOT_TOKEN=123456789:ABC...

# ── Web search (recommended) ────────────────────────────────────────────
# 1000 free Tavily credits/month per key. Comma-separated rotates on quota.
# Without this the agent falls back to Playwright (slow, ~10-30s per query).
# TAVILY_API_KEYS=tvly-...,tvly-...

# ── On-chain (optional) ─────────────────────────────────────────────────
# Enables the etherscan_get_abi tool for ABI decoding in the EVM MCP.
# ETHERSCAN_API_KEY=...

# Custom RPC overrides (defaults use LlamaRPC).
# LONGAI_RPC_URL_ETHEREUM=https://...
# LONGAI_RPC_URL_BASE=https://...
# LONGAI_RPC_URL_ARBITRUM=https://...

# ── Provider override (advanced) ────────────────────────────────────────
# Point at local Ollama instead of OpenRouter. See README "Alternative provider".
# OPENROUTER_BASE_URL=http://localhost:11434/v1

# ── Tracing (debug) ─────────────────────────────────────────────────────
# LONGAI_TRACE_DIR=~/.longai/traces

# ── File-mode secret loading ────────────────────────────────────────────
# Alternative: store the key in its own permissioned file and point at it.
# OPENROUTER_API_KEY_FILE=~/.longai/openrouter.key
